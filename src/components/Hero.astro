---
const greeting = "hey there!, I'm Sol";
const roles = "computer science student · fullstack developer · ui/ux enthusiast";
---

<section id="hero" class="h-[calc(100svh-3.5rem)] flex flex-col items-start justify-center px-4 sm:px-8 md:px-16 overflow-hidden" style="background: linear-gradient(to top, color-mix(in srgb, var(--accent) 15%, transparent), transparent 60%);">

  <h1 class="mb-4 fade-up" style="font-size: clamp(1.8rem, 8vw, 5rem); line-height: 1.1; letter-spacing: 0.03em;" data-i18n="hero.greeting">
    {greeting}
  </h1>

  <p class="text-xs md:text-sm uppercase tracking-[0.25em] text-accent fade-up" style="animation-delay: 1000ms;">
    <span data-i18n="hero.roles">{roles}</span>
  </p>

  <p class="mt-4 md:mt-6 max-w-sm md:max-w-xl text-base md:text-xl text-text-primary leading-relaxed fade-up" style="animation-delay: 1150ms;" data-i18n="hero.description">
    Building web and mobile software, designing interfaces, and crafting digital experiences where functionality meets visual design.
  </p>

  <div class="flex gap-4 mt-6 fade-up" style="animation-delay: 1300ms;">
    <a href="/CV_Sol%20Lopez.pdf" download class="px-6 py-3 bg-black text-white dark:bg-white dark:text-black text-base font-semibold hover:opacity-80 transition-opacity" data-i18n="hero.cv">Download CV</a>
    <a href="#contact" class="px-6 py-3 border-2 border-black dark:border-white text-base font-semibold hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors" data-i18n="hero.contact">Contact me</a>
  </div>
</section>

<style>
  .fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: letterUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes letterUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>
