---

---

<section id="hero" class="py-16 text-left scroll-mt-16">
  <div class="flex items-start gap-6">
    <div class="shrink-0 reveal reveal-delay-1">
      <div class="w-24 h-24 rounded-full bg-gradient-to-br from-accent to-accent-soft flex items-center justify-center text-3xl font-bold text-white shadow-lg">
        S
      </div>
    </div>
    <div class="min-w-0">
      <p class="text-sm text-text-secondary mb-1 reveal reveal-delay-1" data-i18n="hero.greeting">Hola!, soy</p>
      <h1 class="text-5xl font-bold mb-2 reveal reveal-delay-2" style="font-family: 'MonteCarlo', cursive;">Sol</h1>
      <p class="text-text-secondary leading-relaxed reveal reveal-delay-3">
        <span id="typing-text"></span><span id="typing-cursor" class="animate-pulse">|</span>
      </p>
    </div>
  </div>
  <p class="text-text-secondary text-sm mt-4 leading-relaxed reveal reveal-delay-1" data-i18n="hero.desc1">
    Me gusta entender cómo funcionan las cosas, desarmarlas y volver a
    construirlas mejor. Aprendo explorando, experimentando y resolviendo
    problemas reales.
  </p>
  <p class="text-text-secondary text-sm mt-3 leading-relaxed reveal reveal-delay-2" data-i18n="hero.desc2">
    Actualmente profundizo mis conocimientos en estructuras de datos con Java,
    redes con énfasis en ciberseguridad y diseño de interfaces con Figma.
  </p>
  <div class="flex gap-3 mt-4 reveal reveal-delay-1">
    <a
      href="/cv.pdf"
      download
      class="inline-flex items-center gap-2 px-4 py-2 bg-gray-800 text-white text-sm rounded hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 transition active:scale-95"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        ></path>
      </svg>
      <span data-i18n="hero.cv">Descargar CV</span>
    </a>
    <a
      href="#contact"
      class="inline-flex items-center gap-2 px-4 py-2 border border-gray-800 text-gray-800 text-sm rounded hover:bg-gray-100 dark:border-gray-100 dark:text-gray-100 dark:hover:bg-gray-800 transition active:scale-95"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path>
      </svg>
      <span data-i18n="hero.contact">Contact me</span>
    </a>
  </div>
</section>

<script>
  const el = document.getElementById('typing-text');
  const cursor = document.getElementById('typing-cursor');
  if (el) {
    const texts = {
      es: 'Estudiante de Ciencias Informáticas',
      en: 'Computer Science Student'
    };
    const lang = document.documentElement.getAttribute('lang') || 'es';
    const text = texts[lang] || texts.es;
    let i = 0;
    function type() {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(type, 50 + Math.random() * 40);
      } else if (cursor) {
        cursor.style.display = 'none';
      }
    }
    setTimeout(type, 800);
  }

</script>
