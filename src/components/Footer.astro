---
const updated = new Date().toLocaleDateString('es-PY', { year: 'numeric', month: 'short', day: 'numeric' });
---

<footer class="bg-surface px-4 sm:px-8 md:px-16 py-4">
  <div class="flex flex-col sm:flex-row items-center justify-between text-lg text-text-muted gap-1 text-center sm:text-left">
    <p><span data-i18n="footer.credit">Sol Lopez · última actualización</span> {updated}</p>
    <p data-i18n="footer.location">Luque, Paraguay</p>
  </div>
  <p class="text-lg text-text-muted mt-4 text-center sm:text-left" data-i18n="footer.made">Hecho con <a href="https://astro.build" class="underline hover:text-text-secondary">Astro</a></p>
</footer>
