---
const updated = new Date().toLocaleDateString('es-PY', { year: 'numeric', month: 'short', day: 'numeric' });
---

<footer class="bg-surface p-4">
  <div class="max-w-screen-sm mx-auto">
    <div class="flex items-center justify-between text-sm text-text-muted">
      <p> Sol Lopez · última actualización {updated}</p>
      <p> Luque, Paraguay</p>
    </div>
    <p class="text-xs text-text-muted mt-4">Hecho con <a href="https://astro.build" class="underline hover:text-text-secondary">Astro</a></p>
  </div>
</footer>
