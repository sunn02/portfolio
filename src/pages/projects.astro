---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="pb-16">
    <p id="empty-state" data-i18n="projects.empty" class="text-center text-text-muted py-16 hidden">No se encontraron proyectos</p>
    <ul id="project-list" class="flex flex-col gap-6">
      <li data-category="saas" class="project-card rounded-lg overflow-hidden border border-border reveal hover:-translate-y-1 transition-all duration-300">
        <a href="#" class="block cursor-pointer">
          <div class="aspect-video bg-gray-300 dark:bg-gray-700"></div>
        </a>
        <div class="p-4">
          <span class="text-xs text-text-muted">2025</span>
          <h3 class="font-semibold">Nombre del proyecto</h3>
          <p class="text-sm text-text-secondary mt-1">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation.</p>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">React</span>
            <span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">Node.js</span>
            <span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">Tailwind</span>
          </div>
          <div class="flex items-center justify-between mt-3">
            <span class="text-xs font-medium text-text-secondary uppercase tracking-wide">SaaS</span>
              <a href="#" class="text-sm text-link hover:underline inline-flex items-center gap-1">
                View details
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </li>
      <li data-category="diseno" class="project-card rounded-lg overflow-hidden border border-border reveal hover:-translate-y-1 transition-all duration-300">
        <a href="#" class="block cursor-pointer">
          <div class="aspect-video bg-gray-300 dark:bg-gray-700"></div>
        </a>
        <div class="p-4">
          <span class="text-xs text-text-muted">2023</span>
          <h3 class="font-semibold">Nombre del proyecto</h3>
          <p class="text-sm text-text-secondary mt-1">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation.</p>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">Figma</span>
            <span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded">Illustrator</span>
          </div>
          <div class="flex items-center justify-between mt-3">
            <span class="text-xs font-medium text-text-secondary uppercase tracking-wide">Diseño</span>
              <a href="#" class="text-sm text-link hover:underline inline-flex items-center gap-1">
                View details
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </li>
    </ul>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('#filters button');
  const cards = document.querySelectorAll('.project-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('font-bold'));
      btn.classList.add('font-bold');

      const filter = btn.getAttribute('data-filter');
      let visibleCount = 0;
      cards.forEach(card => {
        const cat = card.getAttribute('data-category');
        let show;
        if (filter === 'all') {
          show = true;
        } else if (filter === 'others') {
          show = cat !== 'saas' && cat !== 'diseno';
        } else {
          show = cat === filter;
        }
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      const empty = document.getElementById('empty-state');
      if (empty) empty.style.display = visibleCount === 0 ? '' : 'none';
    });
  });

  document.querySelector('#filters button[data-filter="all"]')?.click();
</script>