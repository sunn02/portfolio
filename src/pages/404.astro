---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
  html, body { overflow: hidden; height: 100%; }
</style>

<Layout>
  <section class="flex flex-col items-center justify-center text-center min-h-[calc(100vh-9rem)]">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-text-secondary mb-8">Página no encontrada</p>
    <a href="/" class="text-accent hover:underline inline-flex items-center gap-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5m7-7l-7 7 7 7"/>
      </svg>
      Volver al inicio
    </a>
  </section>
</Layout>
